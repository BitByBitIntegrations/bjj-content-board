{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-context-budget.sh"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-secrets.sh"
          },
          {
            "type": "command",
            "command": "bash .claude/hooks/guard-protected-paths.sh"
          }
        ]
      }
    ]
  }
}
